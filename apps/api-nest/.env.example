# Copy to .env for local Nest. Express integration: same JWT_SECRET as api-express.
# JWT_SECRET=

# Optional: skip all JWT checks (never in production).
# DISABLE_AUTH=false

# Bearer on protected routes: **off by default in production** (cookie `spybot_access` only).
# Unset → false when NODE_ENV=production, true in dev. Match api-express for proxy + guard behavior.
# AUTH_ALLOW_BEARER=true

# OpenAPI / Swagger
# OPENAPI_ENABLED=1
