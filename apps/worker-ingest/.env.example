# Copy to .env and adjust. No secrets should be committed.

# Ingest DB schema. If unset, DATABASE_URL is used.
DATABASE_URL=postgresql://vahan360:pass123@127.0.0.1:5433/vahan360
# INGEST_DATABASE_URL=postgresql://vahan360:pass123@127.0.0.1:5433/vahan360

# BullMQ Redis connection.
REDIS_URL=redis://127.0.0.1:6379
# BULLMQ_REDIS_URL=redis://127.0.0.1:6379

# Queue names (must match backend enqueue + Bull Board).
# INGEST_QUEUE_NAME=scrape-ingest
# INGEST_CHILD_QUEUE_NAME=scrape-ingest-child
# INGEST_DLQ_QUEUE_NAME=scrape-ingest-dlq
# INGEST_RETRY_QUEUE_NAME=scrape-ingest-retry

# When true/1, after the normal prepare + persist_stub_result children, the master
# also enqueues one child per entry in @vahan360/contracts INGEST_CHILD_JOB_TYPES
# (sliceKey `${type}:${Date.now()}`, Bull jobId includes that sliceKey). Redis/child
# queue depth explodes — keep INGEST_CHILD_CONCURRENCY low or scale replicas/Redis.
# Default false — omit or set false for production unless you load-test this path.
# INGEST_FANOUT_ALL_CHILD_TYPES=false

# When true, worker copies terminal master/child failures to DLQ (same Redis).
# INGEST_DLQ_ENABLED=false

# When true, this process also runs a BullMQ Worker on INGEST_RETRY_QUEUE_NAME that
# re-queues payloads onto master or child (see resolveRetryTarget / `target` / dlqMeta.sourceQueue).
# INGEST_RETRY_WORKER_ENABLED=false

# Default 1. Dedicated retry Helm chart sets this to 1 explicitly.
# INGEST_RETRY_WORKER_CONCURRENCY=1

# Max replayAttempts before retry consumer skips (also honors legacy INGEST_RETRY_MAX_REPLAYS).
# INGEST_RETRY_MAX_REPLAY_ATTEMPTS=5

# Set false on a dedicated retry pod so only the retry consumer runs (see Helm workerRetry).
# INGEST_MAIN_WORKERS_ENABLED=true

# Retry queue: BullMQ Worker re-adds jobs to master or child (target in payload). Off by default.
# INGEST_RETRY_WORKER_ENABLED=false
# INGEST_RETRY_MAX_REPLAYS=5
# INGEST_RETRY_WORKER_CONCURRENCY=2

# After a terminal child-queue failure, optional process-local backoff before DLQ/markFailed
# (reduces hot-loop when many child jobs fail in a row). Off when base is 0/unset.
# INGEST_BACKOFF_BASE_MS=0
# INGEST_BACKOFF_MAX_MS=30000
# INGEST_BACKOFF_MULTIPLIER=2

# BullMQ worker: extend lock / stalled detection for long Playwright steps (ms, min 5000 if set).
# BULLMQ_LOCK_DURATION_MS=
# BULLMQ_STALLED_INTERVAL_MS=

# Worker Prometheus (internal). Requires prom-client dependency.
# METRICS_ENABLED=false
# WORKER_METRICS_PORT=9101

# Persist BullMQ getJobCounts() to system.queue_metrics every N ms (default 30000).
# QUEUE_METRICS_INTERVAL_MS=30000

# Stable worker id for `system.worker_status` (default: hostname + random hex once per process).
# WORKER_ID=ingest-worker-1

# Heartbeat upsert interval (ms). Default 15000.
# WORKER_HEARTBEAT_INTERVAL_MS=15000

# ── Phase 5: optional Playwright smoke ──────────────────────────────────────
# When PLAYWRIGHT_ENABLED=true AND PLAYWRIGHT_SMOKE_URL is set, the master
# worker spins up one chromium tab per job, captures page.title(), runs the
# selector-registry probe for the job kind, and logs an event. Disabled by
# default so CI / boxes without a browser install stay green.
#
# First-time setup: pnpm --filter @vahan360/worker-ingest run playwright:install
# PLAYWRIGHT_ENABLED=false
# PLAYWRIGHT_SMOKE_URL=https://example.com
# PLAYWRIGHT_TIMEOUT_MS=20000
# PLAYWRIGHT_SMOKE_PAGE_KEY=default
# SCRAPER_PORTALS_DIR=  # optional override; defaults to packages/scraper-core/portals
#
# Selector validation controls for smoke parser/registry health.
# Strict=false keeps jobs flowing while surfacing degraded portal signals.
# SELECTOR_VALIDATION_STRICT=false
# SELECTOR_ALERT_FAILURE_THRESHOLD=5
# SELECTOR_ALERT_WINDOW_MS=600000
# SELECTOR_DEGRADED_COOLDOWN_MS=300000

# Optional: distributed browser-manager (same worker image). When `BROWSER_MANAGER_BASE_URL` is set,
# Playwright smoke uses HTTP + CDP (`/v1/context/acquire` → `wsEndpoint`) instead of in-process pool.
# BROWSER_MANAGER_BASE_URL=http://localhost:3005
# BROWSER_MANAGER_TOKEN=shared-secret   # must match server; also sent as X-Browser-Manager-Token
# Optional: forward a user JWT for tenant claims (else rely on X-Tenant-Id from worker).
# BROWSER_MANAGER_FORWARD_JWT=
#
# Optional per-tenant fairness when quotas enabled on browser-manager (needs REDIS_URL): max concurrent
# `/v1/context/acquire` leases per tenant; HTTP 429 `{ "error": "quota_exceeded" }` when exceeded.
# BROWSER_MAX_CONTEXTS_PER_TENANT=8
#
# Pool isolation / ACLs: set a stable slug per deployment or per worker pool.
# WORKER_TENANT_SLUG=default
# WORKER_TENANT_ID=

# ── Per-tenant browser-context quotas ───────────────────────────────────────
# Opt-in fairness layer. All counts are in-process only (single worker pod).
# Cluster-wide quota requires a shared counter (e.g. Redis INCR) — deferred.
#
# JSON map of tenantId → max concurrent contexts. Falls back to "default" key.
# BROWSER_POOL_QUOTAS_JSON={"default":2,"org_acme":4,"org_demo":1}
#
# Scalar default (used when BROWSER_POOL_QUOTAS_JSON is absent).
# 0 or unset = quota disabled (transparent pass-through).
# BROWSER_POOL_TENANT_MAX_CONTEXTS=2
#
# How long to wait for a free slot before rejecting (ms). Default 30000.
# BROWSER_POOL_QUOTA_WAIT_MS=30000
#
# Set to "true" to reject immediately when tenant is at quota (no waiting).
# BROWSER_POOL_QUOTA_REJECT_FAST=false

# OpenTelemetry traces (OTLP HTTP). Off by default.
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=worker-ingest
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
