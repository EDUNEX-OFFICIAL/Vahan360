# Copy to .env and adjust. Matches docker-compose postgres defaults when unset.
DATABASE_URL=postgresql://vahan360:pass123@127.0.0.1:15432/vahan360

# Optional: dedicated Postgres URL for ingest schema (`ingest.*`). If unset, `DATABASE_URL` is used (same DB, ingest + public).
# INGEST_DATABASE_URL=postgresql://vahan360:pass123@127.0.0.1:15432/vahan360

# Dev stub worker: set to 1 or true to poll QUEUED ingest jobs and mark SUCCEEDED (no browser). Optional: INGEST_JOB_POLL_INTERVAL_MS (default 5000).
# Keep this off when REDIS_URL / BULLMQ_REDIS_URL is configured and the BullMQ worker is running.
# INGEST_JOB_POLLER=0

# BullMQ ingest queue. When set, POST /api/v1/scrape-jobs enqueues to Redis after inserting QUEUED DB row.
# If Redis is unavailable, API logs a warning and leaves the DB row queued for fallback processing.
# REDIS_URL=redis://127.0.0.1:6379
# BULLMQ_REDIS_URL=redis://127.0.0.1:6379

# Optional read-through Redis cache for hot GET endpoints (e.g. /api/v1/queues/metrics, TTL 5s).
# No-op when unset/false OR when no Redis URL is configured. Cache failures degrade to fresh reads.
# REDIS_CACHE_ENABLED=false
# INGEST_QUEUE_NAME=scrape-ingest
# INGEST_CHILD_QUEUE_NAME=scrape-ingest-child
# INGEST_DLQ_QUEUE_NAME=scrape-ingest-dlq
# INGEST_RETRY_QUEUE_NAME=scrape-ingest-retry
# Optional DLQ → master/child HTTP replay (JWT + X-Admin-Token). Off by default.
# ADMIN_QUEUE_REPLAY_ENABLED=false
# ADMIN_QUEUE_TOKEN=  # long random; required when replay is enabled
# Same replay cap as worker (invalid or ≤0 → default 5).
# INGEST_RETRY_MAX_REPLAYS=5

# Strict startup validation (DATABASE_URL shape, production JWT length). Throws when true.
# ENV_STRICT=false

# Disable Helmet Content-Security-Policy (useful in dev or behind SSE/proxy quirks).
# HELMET_DISABLE_CSP=0

# POST /api/v1/scrape-jobs — per-IP limit (always) + per-user limit when JWT present (same window/max).
# RATE_LIMIT_SCRAPE_MAX=30
# RATE_LIMIT_WINDOW_MS=60000

# Behind ingress / reverse proxy: set so Express trusts X-Forwarded-For and req.ip + rate-limit keys
# reflect the real client (not the proxy). Optional TRUST_PROXY_HOPS (default 1) = trusted proxy count.
# Mis-set hops can allow IP spoofing — only enable when the value matches your edge topology.
# TRUST_PROXY=false
# TRUST_PROXY_HOPS=1

# Optional: soft global limit for all routes (off when unset or zero).
# RATE_LIMIT_GLOBAL_MAX=300
# RATE_LIMIT_GLOBAL_WINDOW_MS=900000

# Bull Board UI at /admin/queues (JWT required). Optional IP allowlist (comma-separated).
# BULL_BOARD_ENABLED=false
# BULL_BOARD_ALLOWLIST_CSV=127.0.0.1,::1

# Required when NODE_ENV=production: at least 32 characters, not a placeholder.
# Generate:  node scripts/generate-jwt-secret.js
#         or  openssl rand -base64 48
# Rotating this value invalidates all existing JWTs (users re-login).
JWT_SECRET=

# Optional (Mongo removed from runtime paths — kept only if you run legacy scripts)
# MONGODB_URI=mongodb://localhost:27017/spybot
# MONGODB_DB_NAME=khanan_db

BACKEND_PORT=5000

# Nest (apps/api-nest) reverse proxy: GET http://localhost:5000/api/v2/health → Nest GET /health
# Off by default. When off, /api/v2/* is not mounted (404). Treat as internal-only in prod (firewall / mesh), no Express JWT.
# API_V2_PROXY_ENABLED=1
# NEST_INTERNAL_URL=http://127.0.0.1:4000
#
# Optional: mount `/api/vehicle/v2-intel/*` → Nest `/vehicle/*` (processed intelligence reads).
# Requires Nest listening + valid JWT/cookies on Express (same header forwarding as `/api/v2`).
# VEHICLE_INTEL_PROXY_TO_NEST=1
# On Nest (apps/api-nest): OPENAPI_ENABLED=1 → Swagger at http://127.0.0.1:4000/docs (direct; Express does not mount /docs).

# CORS strict allowlist (comma-separated exact origins). In production, wildcard is blocked.
# CORS_ORIGIN_ALLOWLIST=https://app.example.com,https://ops.example.com
# Backward-compat alias:
# CORS_ORIGIN=https://app.example.com

# Bearer header on protected routes (`Authorization: Bearer`): **off by default in production**.
# Unset AUTH_ALLOW_BEARER → false when NODE_ENV=production, true in dev for CLI/scripts.
# Production is cookie-only (`spybot_access`). Set AUTH_ALLOW_BEARER=true only for local tooling or CI smoke.
# AUTH_ALLOW_BEARER=true

# Auth cookies / token lifecycle (httpOnly cookies + refresh rotation)
# AUTH_ACCESS_TTL_SECONDS=900
# AUTH_REFRESH_TTL_SECONDS=2592000
# AUTH_COOKIE_DOMAIN=.example.com
# AUTH_COOKIE_PATH=/
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_SECURE=true
# CSRF_TOKEN_MAX_AGE_MS=86400000

# Auth endpoints rate limiting
# RATE_LIMIT_AUTH_WINDOW_MS=60000
# RATE_LIMIT_AUTH_MAX=20

# Khanan scrape: max inclusive calendar span for POST /api/v1/scrape-jobs (kind khanan_date_range)
SCRAPE_MAX_RANGE_DAYS=31
# Set to 1 or true to allow from/to dates in the future (default: reject)
# SCRAPE_ALLOW_FUTURE_DATES=0

# Optional: after scraper completes, auto-run vehicle summary aggregation for Leads (/api/vehicle/sync logic)
# SCRAPE_AUTO_SYNC_VEHICLES=1

# SSE: GET /api/v1/scrape-jobs/:id/stream — poll interval and comment heartbeat (ms).
# SCRAPE_JOB_SSE_POLL_MS=2000
# SCRAPE_JOB_SSE_HEARTBEAT_MS=15000

# Phase 7 — Prometheus metrics. When METRICS_ENABLED=true, the backend mounts
# GET /metrics with default Node/process metrics + scrape_jobs_enqueued_total,
# scrape_jobs_completed_total, scrape_jobs_status. Disabled by default; keep
# it on a private network (no auth on /metrics).
# METRICS_ENABLED=false
# METRICS_PATH=/metrics

# OpenTelemetry traces (OTLP HTTP). Off by default — no collector required for CI/local unless enabled.
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=vahan360-api-express
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# Optional: OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Health probe freshness threshold for latest worker heartbeat.
# WORKER_HEARTBEAT_STALE_MS=60000
