-----BEGIN PUBLIC KEY-----
# PLACEHOLDER — Replace with the real public key generated by `cosign generate-key-pair`.
#
# Bootstrap steps (run once per team/org):
#   1. cosign generate-key-pair          → produces cosign.key (private) + cosign.pub (public)
#   2. gh secret set COSIGN_PRIVATE_KEY < cosign.key
#   3. gh secret set COSIGN_PASSWORD     # passphrase entered during step 1
#   4. cp cosign.pub cosign.pub          # commit the REAL public key (not this example)
#   5. rm cosign.key                     # never commit the private key
#   6. git add cosign.pub && git commit -m "chore: add cosign public key for image verification"
#
# Verify a signed image after publish:
#   cosign verify --key cosign.pub ghcr.io/<org>/vahan360-api-nest:<tag>
#   cosign download sbom ghcr.io/<org>/vahan360-api-nest:<tag>
#   cosign verify-attestation --type slsaprovenance ghcr.io/<org>/vahan360-api-nest:<tag>
#
# If COSIGN_PRIVATE_KEY secret is absent, publish.yml falls back to keyless OIDC
# signing via Sigstore/Rekor — no cosign.pub needed for that path.
-----END PUBLIC KEY-----
