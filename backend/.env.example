# Copy to .env and adjust. Matches docker-compose postgres defaults when unset.
DATABASE_URL=postgresql://vahan360:pass123@127.0.0.1:5433/vahan360

# Required when NODE_ENV=production: at least 32 characters, not a placeholder.
# Generate:  node scripts/generate-jwt-secret.js
#         or  openssl rand -base64 48
# Rotating this value invalidates all existing JWTs (users re-login).
JWT_SECRET=

# Optional (Mongo removed from runtime paths — kept only if you run legacy scripts)
# MONGODB_URI=mongodb://localhost:27017/spybot
# MONGODB_DB_NAME=khanan_db

BACKEND_PORT=5000

# Khanan scrape: max inclusive calendar span for POST /api/selenium/scrape-range (and validated GET /by-date-range)
SCRAPE_MAX_RANGE_DAYS=31
# Set to 1 or true to allow from/to dates in the future (default: reject)
# SCRAPE_ALLOW_FUTURE_DATES=0

# Optional: after scraper completes, auto-run vehicle summary aggregation for Leads (/api/vehicle/sync logic)
# SCRAPE_AUTO_SYNC_VEHICLES=1
